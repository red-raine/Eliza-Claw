{
  "meta": {
    "name": "eliza-claw",
    "version": "0.1.0",
    "author": "",
    "description": "A micro AI OS inspired by Eliza, text adventures, and OpenClaw"
  },

  "config": {
    "initial": "How do you do. Please tell me your problem.",
    "final": "Goodbye. Thank you for talking to me.",
    "heartbeat_interval": 1.0,
    "memory_path": "./memory/",
    "response_mode": "varied",
    "multi_user": true,
    "default_user": null,
    "session_timeout": 3600
  },

  "response_settings": {
    "mode": "varied",
    "avoid_repeat_last": 3,
    "track_usage": true,
    "fallback_style": "eliza",
    "personality": "eliza_therapist"
  },

  "personalities": {
    "eliza_therapist": {
      "tone": "inquisitive",
      "contractions": true,
      "reflective": true,
      "style": "turns questions back on user"
    },
    "friendly": {
      "tone": "warm",
      "contractions": true,
      "reflective": false
    },
    "professional": {
      "tone": "direct",
      "contractions": false,
      "reflective": false
    }
  },

  "memory": {
    "users": {
      "path": "users.json",
      "schema": {
        "users": {
          "known": [],
          "current": null,
          "last_active": null
        }
      }
    },
    "user_profile": {
      "schema": {
        "id": null,
        "name": null,
        "aliases": [],
        "location": null,
        "timezone": null,
        "interests": [],
        "relationships": {},
        "preferences": {},
        "history": {
          "first_met": null,
          "conversations": 0,
          "last_seen": null,
          "topics_discussed": [],
          "emotions_expressed": []
        },
        "facts_known": []
      }
    },
    "session": {
      "schema": {
        "active_user": null,
        "started": null,
        "turns": 0,
        "recent_topics": []
      }
    },
    "response_history": {
      "schema": {
        "plugin": null,
        "templates_used": [],
        "last_response": null
      }
    }
  },

  "transformers": {
    "pre": {
      "dont": "don't",
      "cant": "can't",
      "wont": "won't",
      "recollect": "remember",
      "dreamt": "dreamed",
      "dreams": "dream",
      "maybe": "perhaps",
      "certainly": "yes",
      "machine": "computer",
      "computers": "computer",
      "were": "was",
      "you're": "you are",
      "i'm": "i am",
      "same": "alike"
    },
    "post": {
      "am": "are",
      "your": "my",
      "me": "you",
      "myself": "yourself",
      "yourself": "myself",
      "i": "you",
      "you": "I",
      "my": "your",
      "i'm": "you are"
    }
  },

  "synonyms": {
    "belief": ["feel", "think", "believe", "wish"],
    "desire": ["want", "need"],
    "sad": ["unhappy", "depressed", "sick", "down", "blue"],
    "happy": ["elated", "glad", "better", "great", "good"],
    "family": ["mother", "mom", "father", "dad", "sister", "brother", "wife", "husband", "children", "child", "son", "daughter"],
    "everyone": ["everybody", "nobody", "noone", "anyone"],
    "weather": ["forecast", "temperature", "rain", "sunny", "cold", "hot"],
    "search": ["find", "look", "query", "lookup", "google"],
    "news": ["headlines", "articles", "updates", "stories"],
    "time": ["clock", "hour", "date"],
    "quit": ["bye", "goodbye", "exit", "done", "later"],
    "yes": ["yeah", "yep", "sure", "ok", "okay", "right"],
    "no": ["nope", "nah", "never", "don't"]
  },

  "responses": {
    "generic": {
      "confused": [
        "I'm not sure I understand you fully.",
        "Please go on.",
        "What does that suggest to you?",
        "Do you feel strongly about discussing such things?",
        "Can you elaborate on that?",
        "That's quite interesting.",
        "You say {input}?",
        "Can you elaborate on that?"
      ],
      "continue": [
        "Please go on.",
        "Tell me more.",
        "What else?",
        "Go on...",
        "I'm listening.",
        "What does that suggest to you?"
      ],
      "no_plugin": [
        "I don't have a plugin for that yet.",
        "That's outside my current skills.",
        "Maybe someday I'll learn how to help with that.",
        "Not something I can do right now.",
        "What about that interests you?"
      ],
      "error": [
        "Something went wrong there.",
        "Hit a snag. Try again?",
        "That didn't work as expected.",
        "Oops, let's try that once more."
      ],
      "acknowledge": [
        "Got it.",
        "Understood.",
        "I see.",
        "Noted.",
        "Okay.",
        "Right."
      ],
      "greeting": [
        "How do you do. Please state your problem.",
        "Hi. What seems to be your problem?",
        "Hello. How can I help you today?"
      ],
      "uncertain": [
        "You don't seem quite certain.",
        "Why the uncertain tone?",
        "Can't you be more positive?",
        "You aren't sure?",
        "Don't you know?"
      ],
      "positive": [
        "You seem to be quite positive.",
        "You are sure.",
        "I see.",
        "I understand."
      ],
      "negative": [
        "Are you saying no just to be negative?",
        "You are being a bit negative.",
        "Why not?",
        "Why 'no'?"
      ]
    },

    "identity": {
      "ask_name": [
        "What should I call you?",
        "What's your name?",
        "Who am I speaking with?",
        "Do I know you?"
      ],
      "confirm_identity": [
        "Are you {name}?",
        "Is this {name}?",
        "{name}, is that you?"
      ],
      "not_recognized": [
        "I don't think we've met. What's your name?",
        "You're new to me. Who are you?",
        "I don't recognize you. Have we met?",
        "Who is this?"
      ],
      "ask_if_met": [
        "Have we met before?",
        "Do you know me?",
        "Should I know you?"
      ],
      "greet_known": [
        "Hello, {name}. Good to see you again.",
        "Welcome back, {name}.",
        "{name}! How have you been?",
        "Hi {name}. What brings you here?"
      ],
      "greet_new": [
        "Hello! I don't think we've met.",
        "Hi there! You're new, aren't you?",
        "I don't believe we've been introduced."
      ],
      "ask_relationship": [
        "How do you know {other}?",
        "What's your relationship with {other}?",
        "Are you friends with {other}?",
        "Tell me about {other}."
      ],
      "ask_presence": [
        "Are you supposed to be here?",
        "What brings you here?",
        "Why are you here?",
        "Is there something you need?"
      ],
      "learn_about_other": [
        "Tell me more about {other}.",
        "What's {other} like?",
        "How did you meet {other}?",
        "What does {other} do?"
      ]
    },

    "remember": {
      "ask_remember": [
        "Do you often think of {topic}?",
        "Does thinking of {topic} bring anything else to mind?",
        "What else do you remember?",
        "Why do you remember {topic} just now?",
        "What in the present situation reminds you of {topic}?",
        "What is the connection between me and {topic}?"
      ],
      "ask_remember_me": [
        "Did you think I would forget {topic}?",
        "Why do you think I should recall {topic} now?",
        "What about {topic}?",
        "You mentioned {topic}?"
      ],
      "i_remember": [
        "I remember that you {fact}.",
        "You told me about {fact}.",
        "Last time, you mentioned {fact}."
      ],
      "dont_remember": [
        "I don't recall that.",
        "That doesn't ring a bell.",
        "Are you sure you told me that?"
      ]
    },

    "dream": {
      "interpret": [
        "What does that dream suggest to you?",
        "Do you dream often?",
        "What persons appear in your dreams?",
        "Do you believe that dreams have something to do with your problems?",
        "Have you ever fantasized {topic} while you were awake?",
        "Have you ever dreamed {topic} before?"
      ]
    },

    "emotions": {
      "sad_response": [
        "I am sorry to hear that you are {feeling}.",
        "Do you think that coming here will help you not to be {feeling}?",
        "I'm sure it's not pleasant to be {feeling}.",
        "Can you explain what made you {feeling}?"
      ],
      "happy_response": [
        "How have I helped you to be {feeling}?",
        "What makes you {feeling} just now?",
        "Can you explain why you are suddenly {feeling}?",
        "That's wonderful that you're {feeling}."
      ],
      "desire_response": [
        "What would it mean to you if you got {desire}?",
        "Why do you want {desire}?",
        "Suppose you got {desire} soon?",
        "What if you never got {desire}?",
        "What does wanting {desire} have to do with this discussion?"
      ],
      "cant_response": [
        "How do you think that you can't {action}?",
        "Have you tried?",
        "Perhaps you could {action} now.",
        "Do you really want to be able to {action}?"
      ]
    },

    "computer": {
      "response": [
        "Do computers worry you?",
        "Why do you mention computers?",
        "What do you think machines have to do with your problem?",
        "Don't you think computers can help people?",
        "What about machines worries you?",
        "What do you think about machines?"
      ]
    },

    "apology": {
      "response": [
        "Please don't apologise.",
        "Apologies are not necessary.",
        "I've told you that apologies are not required.",
        "What are you apologizing for?"
      ]
    },

    "why": {
      "why_dont_you": [
        "Do you believe I don't {action}?",
        "Perhaps I will {action} in good time.",
        "Should you {action} yourself?",
        "You want me to {action}?"
      ],
      "why_cant_i": [
        "Do you think you should be able to {action}?",
        "Do you want to be able to {action}?",
        "Do you believe this will help you to {action}?",
        "Have you any idea why you can't {action}?"
      ],
      "general": [
        "Why do you ask?",
        "Does that question interest you?",
        "What is it you really wanted to know?",
        "Are such questions much on your mind?",
        "What answer would please you most?",
        "What do you think?",
        "What comes to mind when you ask that?",
        "Have you asked such questions before?",
        "Have you asked anyone else?"
      ]
    },

    "always": {
      "response": [
        "Can you think of a specific example?",
        "When?",
        "What incident are you thinking of?",
        "Really, always?"
      ]
    },

    "everyone": {
      "response": [
        "Really, everyone?",
        "Surely not everyone.",
        "Can you think of anyone in particular?",
        "Who, for example?",
        "Are you thinking of a very special person?",
        "Who, may I ask?",
        "Someone special perhaps?",
        "You have a particular person in mind, don't you?",
        "Who do you think you're talking about?"
      ]
    },

    "alike": {
      "response": [
        "In what way?",
        "What resemblance do you see?",
        "What does that similarity suggest to you?",
        "What other connections do you see?",
        "What do you suppose that resemblance means?",
        "What is the connection, do you suppose?",
        "Could there really be some connection?",
        "How?"
      ]
    },

    "because": {
      "response": [
        "Is that the real reason?",
        "Don't any other reasons come to mind?",
        "Does that reason seem to explain anything else?",
        "What other reasons might there be?"
      ]
    },

    "family": {
      "response": [
        "Tell me more about your family.",
        "Who else in your family {context}?",
        "Your {relation}?",
        "What else comes to mind when you think of your {relation}?"
      ]
    }
  },

  "plugins": [
    {
      "name": "identity",
      "enabled": true,
      "priority": 100,
      "triggers": ["on_start", "on_unknown_user", "on_user_switch"],

      "hooks": {
        "identify": {
          "function": "identity.identify_user",
          "params": []
        },
        "confirm": {
          "function": "identity.confirm_user",
          "params": ["name_guess"]
        },
        "register": {
          "function": "identity.register_user",
          "params": ["name"],
          "learn": true
        },
        "switch": {
          "function": "identity.switch_user",
          "params": ["name"]
        },
        "ask_relationship": {
          "function": "identity.query_relationship",
          "params": ["other_user"],
          "learn": true
        }
      },

      "responses": {
        "confirm_identity": [
          "Are you {name}?",
          "Is this {name}?",
          "{name}, is that you?"
        ],
        "not_recognized": [
          "I don't think we've met. What's your name?",
          "You're new to me. Who are you?",
          "I don't recognize you. Have we met?"
        ],
        "ask_if_known": [
          "Do I know you?",
          "Have we met before?",
          "Should I know who you are?"
        ],
        "greet_known": [
          "Hello, {name}. Good to see you again.",
          "Welcome back, {name}. Last time we talked about {last_topic}.",
          "{name}! I remember you. How have you been?"
        ],
        "greet_new": [
          "Hello! I don't think we've met. I'm Eliza-Claw.",
          "Hi there! You're new. What's your name?",
          "I don't believe we've been introduced. Who am I speaking with?"
        ],
        "ask_about_other": [
          "How do you know {other}?",
          "What's your relationship with {other}?",
          "Are you a friend of {other}?",
          "Tell me about {other}."
        ],
        "learn_about_other": [
          "Interesting. What is {other} like?",
          "What does {other} do?",
          "How did you meet {other}?"
        ],
        "other_likes": [
          "I know that {other} likes {interests}. Do you like those too?",
          "{other} has mentioned being interested in {interests}.",
          "Fun fact: {other} is into {interests}."
        ],
        "suspicious": [
          "Are you supposed to be here?",
          "What brings you here?",
          "Is there something specific you need?",
          "Why are you here?"
        ],
        "registered": [
          "Nice to meet you, {name}. I'll remember you.",
          "Got it, {name}. Welcome.",
          "Hello {name}. I'm Eliza-Claw. What brings you here?"
        ],
        "already_known": [
          "Oh, I know you! You're {name}.",
          "{name}! I remember you."
        ]
      }
    },

    {
      "name": "weather",
      "enabled": true,
      "priority": 10,

      "hooks": {
        "current": {
          "function": "weather.current",
          "params": ["location"],
          "cache_ttl": 1800
        },
        "forecast": {
          "function": "weather.forecast",
          "params": ["location", "days"],
          "cache_ttl": 3600
        }
      },

      "responses": {
        "current": [
          "Currently {temp}° and {condition} in {location}.",
          "Right now in {location}: {temp}°, {condition}.",
          "Weather check for {location}: {condition}, {temp}°.",
          "It's {temp}° with {condition} conditions in {location}.",
          "{location} is seeing {temp}° and {condition} right now."
        ],
        "forecast": [
          "{days}-day forecast for {location}: {summary}.",
          "Looking ahead in {location}: {summary} over the next {days} days.",
          "Here's what's coming for {location}: {summary}."
        ],
        "unknown_location": [
          "I don't know your location yet. Where should I check?",
          "What location should I look up?",
          "Where are you thinking of?"
        ],
        "learn_location": [
          "Want me to remember {location} as your location?",
          "Should I save {location} for future weather checks?",
          "Make {location} your default?"
        ]
      }
    },

    {
      "name": "search",
      "enabled": true,
      "priority": 8,

      "hooks": {
        "web": {
          "function": "search.web",
          "params": ["query"],
          "sources": ["duckduckgo", "wikipedia"]
        }
      },

      "responses": {
        "result": [
          "Found this: {title} — {snippet}",
          "Here's what I found: {title}. {snippet}",
          "Top result: {title}",
          "Got something: {title} - {snippet}"
        ],
        "no_results": [
          "Couldn't find anything on that.",
          "No results for {query}.",
          "Nothing came up for {query}."
        ],
        "learn_interest": [
          "Want me to add '{query}' to your interests?",
          "Should I remember that you're interested in {query}?",
          "Add {query} to topics I should follow for you?"
        ]
      }
    },

    {
      "name": "reminder",
      "enabled": true,
      "priority": 9,

      "hooks": {
        "add": {
          "function": "reminder.add",
          "params": ["task", "when"]
        },
        "list": {
          "function": "reminder.list",
          "params": []
        }
      },

      "responses": {
        "added": [
          "Got it. I'll remind you about {task} {when}.",
          "Reminder set: {task} {when}.",
          "I'll remember to bug you about {task} {when}."
        ],
        "list_header": [
          "Here's what you've got pending:",
          "Your reminders:",
          "Things to do:"
        ],
        "empty": [
          "No pending reminders.",
          "Your list is clear.",
          "All caught up!"
        ]
      }
    },

    {
      "name": "memory_recall",
      "enabled": true,
      "priority": 5,

      "hooks": {
        "recall_user": {
          "function": "memory.get_user_facts",
          "params": ["user_id"]
        },
        "recall_topic": {
          "function": "memory.get_topic_history",
          "params": ["topic"]
        },
        "save_fact": {
          "function": "memory.save_fact",
          "params": ["fact", "category"],
          "learn": true
        }
      },

      "responses": {
        "recall": [
          "I remember that you {fact}.",
          "You told me about {fact}.",
          "Last time, you mentioned {fact}.",
          "I have in my records that {fact}."
        ],
        "dont_recall": [
          "I don't recall that.",
          "That doesn't ring a bell.",
          "Are you sure you told me that?",
          "I don't have that in my memory."
        ],
        "ask_remember": [
          "Do you often think of {topic}?",
          "Does thinking of {topic} bring anything else to mind?",
          "Why do you remember {topic} just now?",
          "What in the present situation reminds you of {topic}?"
        ],
        "confirm_fact": [
          "So you're telling me that {fact}. Is that right?",
          "Let me make sure I understand: {fact}?",
          "I want to remember this. You said {fact}?"
        ]
      }
    },

    {
      "name": "eliza_conversation",
      "enabled": true,
      "priority": 1,

      "hooks": {
        "reflect": {
          "function": "eliza.reflect",
          "params": ["input", "emotion"]
        },
        "question_back": {
          "function": "eliza.question_back",
          "params": ["topic"]
        }
      },

      "responses": {
        "reflect_feeling": [
          "You seem {emotion}.",
          "I sense that you're {emotion}.",
          "You sound {emotion} about this."
        ],
        "question_purpose": [
          "Why do you ask?",
          "What is it you really want to know?",
          "Does that question interest you?",
          "What comes to mind when you ask that?"
        ],
        "turn_back": [
          "We were discussing you, not me.",
          "You're not really talking about me, are you?",
          "What are your feelings now?"
        ],
        "probe": [
          "What does that suggest to you?",
          "Do you feel strongly about that?",
          "Can you elaborate on that?",
          "Tell me more."
        ]
      }
    }
  ],

  "keys": [
    {
      "keyword": "i",
      "priority": 2,
      "plugin": "eliza_conversation",
      "decomps": [
        {
          "pattern": "* i am * @sad *",
          "hook": "reflect",
          "params": {"emotion": 3, "context": 2},
          "response": "emotions.sad_response"
        },
        {
          "pattern": "* i am * @happy *",
          "hook": "reflect",
          "params": {"emotion": 3, "context": 2},
          "response": "emotions.happy_response"
        },
        {
          "pattern": "* i @desire *",
          "hook": "reflect",
          "params": {"desire": 3},
          "response": "emotions.desire_response"
        },
        {
          "pattern": "* i @cannot *",
          "hook": "reflect",
          "params": {"action": 3},
          "response": "emotions.cant_response"
        },
        {
          "pattern": "* i remember *",
          "hook": "reflect",
          "params": {"topic": 3},
          "response": "remember.ask_remember",
          "learn": {
            "category": "memory",
            "fact": 3
          }
        },
        {
          "pattern": "* i * @belief * i *",
          "responses": [
            "Do you really think so?",
            "But you are not sure you {3}.",
            "Do you really doubt you {3}?"
          ]
        },
        {
          "pattern": "* i don't *",
          "responses": [
            "Don't you really {2}?",
            "Why don't you {2}?",
            "Do you wish to be able to {2}?",
            "Does that trouble you?"
          ]
        },
        {
          "pattern": "* i feel *",
          "hook": "reflect",
          "params": {"emotion": 3},
          "learn": {
            "category": "emotions",
            "fact": 3
          }
        }
      ]
    },

    {
      "keyword": "you",
      "priority": 2,
      "plugin": "eliza_conversation",
      "decomps": [
        {
          "pattern": "* you remind me of *",
          "response": "alike.response"
        },
        {
          "pattern": "* you are *",
          "responses": [
            "What makes you think I am {2}?",
            "Does it please you to believe I am {2}?",
            "Do you sometimes wish you were {2}?",
            "Perhaps you would like to be {2}."
          ]
        },
        {
          "pattern": "* you * me *",
          "responses": [
            "Why do you think I {2} you?",
            "You like to think I {2} you, don't you?",
            "What makes you think I {2} you?",
            "Really, I {2} you?",
            "Do you wish to believe I {2} you?",
            "Suppose I did {2} you, what would that mean?"
          ]
        },
        {
          "pattern": "* you *",
          "response": "eliza_conversation.responses.turn_back"
        }
      ]
    },

    {
      "keyword": "remember",
      "priority": 5,
      "plugin": "memory_recall",
      "decomps": [
        {
          "pattern": "* i remember *",
          "hook": "recall_topic",
          "params": {"topic": 3},
          "response": "remember.ask_remember"
        },
        {
          "pattern": "* do you remember *",
          "hook": "recall_topic",
          "params": {"topic": 3},
          "response": "remember.ask_remember_me"
        },
        {
          "pattern": "* you remember *",
          "hook": "recall_topic",
          "params": {"topic": 3},
          "response": "remember.ask_remember_me"
        }
      ]
    },

    {
      "keyword": "dream",
      "priority": 4,
      "plugin": "eliza_conversation",
      "decomps": [
        {
          "pattern": "* i dreamed *",
          "response": "dream.interpret",
          "learn": {
            "category": "dreams",
            "fact": 3
          }
        },
        {
          "pattern": "* dream *",
          "response": "dream.interpret"
        }
      ]
    },

    {
      "keyword": "why",
      "priority": 3,
      "plugin": "eliza_conversation",
      "decomps": [
        {
          "pattern": "* why don't you *",
          "response": "why.why_dont_you",
          "params": {"action": 3}
        },
        {
          "pattern": "* why can't i *",
          "response": "why.why_cant_i",
          "params": {"action": 3}
        },
        {
          "pattern": "* why *",
          "response": "why.general"
        }
      ]
    },

    {
      "keyword": "because",
      "priority": 1,
      "plugin": "eliza_conversation",
      "decomps": [
        {
          "pattern": "*",
          "response": "because.response"
        }
      ]
    },

    {
